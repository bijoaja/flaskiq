FLASK_APP=server.py
FLASK_ENV=development
FLASK_DEBUG=TRUE
FLASK_RUN_PORT=8080

# Database — SQLite for dev, MySQL for prod
DATABASE_URL=sqlite:///flaskiq.db
# DATABASE_URL=mysql+pymysql://root:root123@flaskiq_db:3306/flaskiq_db

# Flask security keys
SECRET_KEY=change-me-in-production
JWT_KEY=change-me-jwt-secret
JWT_EXPIRY_MINUTES=60

# AI provider: "ollama" (local) or "openai"
AI_PROVIDER=ollama

# Ollama (used when AI_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenAI (used when AI_PROVIDER=openai)
AI_KEY=sk-YOUR_OPENAI_KEY_HERE
OPENAI_MODEL=gpt-4o-mini
